---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExploreFilter from '../components/ExploreFilter.tsx';
import { proposals } from '../data/proposals/index';
import { themes } from '../data/themes';
---

<BaseLayout title="Utforska — Hela Stenungsund" description="Sök och filtrera bland 100 förslag för Stenungsund">
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="text-center mb-10">
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl text-charcoal mb-4">
          Utforska alla förslag
        </h1>
        <p class="text-muted max-w-2xl mx-auto leading-relaxed text-lg">
          Sök, filtrera och hitta de idéer som engagerar dig mest.
        </p>
      </div>
      <ExploreFilter client:load proposals={proposals} themes={themes} />
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { themes } from '../data/themes';
import { proposals } from '../data/proposals/index';

const quickWinCount = proposals.filter(p => p.timeline === 'Quick win').length;
const uniqueLocations = new Set(proposals.map(p => p.location)).size;

const featuredIds = [1, 11, 21, 42, 55, 81];
const featuredProposals = featuredIds
  .map(id => proposals.find(p => p.id === id))
  .filter((p): p is typeof proposals[number] => p !== undefined);

const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'Maj', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dec'];
---

<BaseLayout title="Hela Stenungsund — 100 förslag för hela kommunen">

  <!-- 1. Hero Section -->
  <section class="relative text-white overflow-hidden">
    <img src="/images/hero.png" alt="Panorama over Stenungsund" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-br from-ocean/80 via-ocean/70 to-[#152d4a]/80"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 text-center">
      <span class="inline-block bg-white/15 backdrop-blur-sm text-white text-sm font-medium px-4 py-2 rounded-full mb-8 border border-white/20">
        100 förslag &middot; 10 teman &middot; 1 kommun
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl leading-tight mb-6">
        Framtidens Stenungsund<br class="hidden sm:block" /> börjar här
      </h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
        100 konkreta idéer för att göra hela Stenungsund mer levande, lockande och tillgängligt. Inga klagomål, bara förslag.
      </p>

      <!-- Search box (visual, links to /utforska) -->
      <a href="/utforska" class="group block max-w-xl mx-auto mb-8">
        <div class="flex items-center bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl px-5 py-4 hover:bg-white/15 transition-colors">
          <svg class="w-5 h-5 text-white/60 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="text-white/50 text-left">Sök bland 100 förslag...</span>
        </div>
      </a>

      <a href="/utforska" class="inline-flex items-center bg-sunset hover:bg-[#d4662f] text-white font-semibold px-8 py-3.5 rounded-xl transition-colors text-lg shadow-lg shadow-sunset/25">
        Utforska alla
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>

  <!-- 2. Disclaimer Banner -->
  <section class="bg-amber-50 border-y border-amber-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm text-amber-800 leading-relaxed">
          <strong>OBS:</strong> Den här sajten är AI-genererad som ett koncept och experiment. Texterna är utkast som behöver bearbetas vidare. Syftet är att visa ett format och starta en diskussion.
          <a href="/om" class="text-amber-900 font-semibold underline underline-offset-2 hover:text-amber-700 ml-1">Läs mer &rarr;</a>
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Stats Bar -->
  <section class="bg-white border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-ocean mb-1">100</div>
          <div class="text-sm text-muted font-medium">Förslag</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-ocean mb-1">10</div>
          <div class="text-sm text-muted font-medium">Teman</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-ocean mb-1">{quickWinCount}</div>
          <div class="text-sm text-muted font-medium">Quick wins</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-ocean mb-1">{uniqueLocations}</div>
          <div class="text-sm text-muted font-medium">Platser</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Theme Grid -->
  <section class="bg-sand">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl text-charcoal mb-4">10 teman, 100 idéer</h2>
        <p class="text-muted max-w-2xl mx-auto leading-relaxed">
          Varje tema utgår från en fråga som invånarna ställer sig. Klicka på ett tema för att utforska dess 10 förslag.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {themes.map(theme => (
          <a href={`/tema/${theme.id}`} class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-border hover:border-ocean/30 transition-all">
            <div class="text-3xl mb-3">{theme.emoji}</div>
            <div class="text-xs text-muted font-medium mb-1">Tema {theme.id}</div>
            <h3 class="font-heading text-lg text-charcoal group-hover:text-ocean transition-colors mb-1">{theme.name}</h3>
            <p class="text-xs text-muted mb-3">{theme.subtitle}</p>
            <p class="text-xs text-charcoal/70 italic mb-4 line-clamp-2">&ldquo;{theme.question}&rdquo;</p>
            <span class="text-xs text-ocean font-semibold group-hover:underline">Se 10 förslag &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Featured Proposals -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <h2 class="font-heading text-3xl md:text-4xl text-charcoal mb-2">Utvalda förslag</h2>
          <p class="text-muted">Ett smakprov från varje del av kommunen.</p>
        </div>
        <a href="/utforska" class="text-ocean font-semibold hover:underline whitespace-nowrap">Se alla 100 &rarr;</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProposals.map(proposal => {
          const theme = themes.find(t => t.id === proposal.themeId);
          return (
            <a href={`/forslag/${proposal.id}`} class="group bg-sand rounded-xl p-6 hover:shadow-md border border-border hover:border-ocean/30 transition-all flex flex-col">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs bg-white text-muted px-2 py-1 rounded-md font-medium">
                  {theme?.emoji} {theme?.name}
                </span>
                <span class="text-xs text-muted font-mono">#{proposal.id}</span>
              </div>
              <h3 class="font-heading text-lg text-charcoal group-hover:text-ocean transition-colors mb-1">{proposal.title}</h3>
              <p class="text-sm text-muted mb-3">{proposal.subtitle}</p>
              <p class="text-sm text-charcoal/70 leading-relaxed mb-4 line-clamp-3 flex-1">{proposal.what}</p>
              <div class="flex flex-wrap gap-2 mt-auto">
                <span class="text-xs bg-white text-muted px-2 py-0.5 rounded-full">{proposal.cost}</span>
                <span class="text-xs bg-white text-muted px-2 py-0.5 rounded-full">{proposal.timeline}</span>
                <span class="text-xs bg-white text-muted px-2 py-0.5 rounded-full">{proposal.season}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 6. Perspective Section -->
  <section class="bg-sand">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl aspect-[4/3] overflow-hidden">
          <img src="/images/hero.png" alt="Stenungsund panorama" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div>
          <h2 class="font-heading text-3xl md:text-4xl text-charcoal mb-6">Perspektivet är utifrån och in</h2>
          <p class="text-muted leading-relaxed mb-8">
            Vi utgår från vad människor vill uppleva, inte vad organisationer ansvarar för. Inga klagomål, inga pekpinnar, bara konkreta idéer som kan genomföras.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/utforska" class="inline-flex items-center justify-center bg-sunset hover:bg-[#d4662f] text-white font-semibold px-6 py-3 rounded-xl transition-colors shadow-sm">
              Utforska alla 100 förslag
            </a>
            <a href="/om" class="inline-flex items-center justify-center border-2 border-ocean text-ocean hover:bg-ocean hover:text-white font-semibold px-6 py-3 rounded-xl transition-colors">
              Om projektet
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Year Wheel Preview -->
  <section class="bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-charcoal mb-4">Alltid en anledning att besöka Stenungsund</h2>
      <p class="text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
        Årshjulet säkerställer att det alltid finns något att uppleva.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        {monthNames.map((name, i) => (
          <a
            href={`/arshjul?month=${i + 1}`}
            class="bg-sand hover:bg-ocean hover:text-white text-charcoal font-medium text-sm px-5 py-2.5 rounded-full border border-border hover:border-ocean transition-all"
          >
            {name}
          </a>
        ))}
      </div>
      <a href="/arshjul" class="inline-flex items-center text-ocean font-semibold hover:underline text-lg">
        Se hela årshjulet
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>

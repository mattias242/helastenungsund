---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { themes } from '../../data/themes';
import { proposals } from '../../data/proposals';

export function getStaticPaths() {
  return proposals.map((p) => ({
    params: { id: String(p.id) },
    props: { proposal: p },
  }));
}

const { proposal } = Astro.props;
const theme = themes.find((t) => t.id === proposal.themeId)!;
const themeProposals = proposals.filter((p) => p.themeId === proposal.themeId);
const currentIndex = themeProposals.findIndex((p) => p.id === proposal.id);
const prevProposal = themeProposals[currentIndex - 1] ?? null;
const nextProposal = themeProposals[currentIndex + 1] ?? null;

function costColor(cost: string) {
  switch (cost) {
    case 'Liten': return 'bg-green-100 text-green-800';
    case 'Medel': return 'bg-amber-100 text-amber-800';
    case 'Stor': return 'bg-red-100 text-red-800';
    default: return 'bg-gray-100 text-gray-800';
  }
}

function timelineColor(timeline: string) {
  switch (timeline) {
    case 'Quick win': return 'bg-green-100 text-green-800';
    case 'Medel': return 'bg-blue-100 text-blue-800';
    case 'Långsiktig': return 'bg-purple-100 text-purple-800';
    default: return 'bg-gray-100 text-gray-800';
  }
}

function sustainabilityWidth(score: number) {
  return `${(score / 5) * 100}%`;
}

function sustainabilityColor(score: number) {
  if (score >= 4) return 'bg-green-500';
  if (score >= 3) return 'bg-amber-500';
  return 'bg-red-400';
}
---

<BaseLayout title={`${proposal.title} - Hela Stenungsund`} description={proposal.subtitle}>
  <!-- Breadcrumb -->
  <div class="bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center text-sm text-muted space-x-2">
        <a href="/" class="hover:text-ocean transition-colors">Hem</a>
        <span>&rsaquo;</span>
        <a href={`/tema/${theme.id}`} class="hover:text-ocean transition-colors">
          {theme.emoji} {theme.name}
        </a>
        <span>&rsaquo;</span>
        <span class="text-charcoal font-medium">#{proposal.id}</span>
      </nav>
    </div>
  </div>

  <!-- Story Block -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <blockquote class="border-l-4 border-sunset pl-6 py-2 italic text-charcoal/80 text-lg leading-relaxed max-w-3xl">
        {proposal.story}
      </blockquote>
    </div>
  </section>

  <!-- Header -->
  <section class="bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
      <a href={`/tema/${theme.id}`} class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-ocean/10 text-ocean text-sm font-medium hover:bg-ocean/20 transition-colors mb-4">
        {theme.emoji} {theme.name}
      </a>

      <p class="text-sm text-muted font-semibold uppercase tracking-wider mb-2">Forslag #{proposal.id}</p>

      <h1 class="text-3xl md:text-4xl lg:text-5xl text-ocean mb-3">{proposal.title}</h1>
      <p class="text-lg text-muted mb-6">{proposal.subtitle}</p>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${costColor(proposal.cost)}`}>
          {proposal.cost} kostnad
        </span>
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${timelineColor(proposal.timeline)}`}>
          {proposal.timeline}
        </span>
        <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-sand text-muted border border-border">
          {proposal.season}
        </span>
        <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-sand text-muted border border-border">
          {proposal.location}
        </span>
      </div>
    </div>
  </section>

  <!-- Main Content + Sidebar -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-10">
      <!-- Left Column: Main Content -->
      <div class="space-y-10">
        <!-- Vad -->
        <div>
          <h2 class="text-2xl text-ocean mb-4">Vad</h2>
          <p class="text-charcoal/80 leading-relaxed">{proposal.what}</p>
        </div>

        <!-- Varfor -->
        <div>
          <h2 class="text-2xl text-ocean mb-4">Varfor</h2>
          <p class="text-charcoal/80 leading-relaxed">{proposal.why}</p>
        </div>

        <!-- Vem -->
        <div>
          <h2 class="text-2xl text-ocean mb-4">Vem</h2>
          <p class="text-charcoal/80 leading-relaxed mb-3">
            <strong>{proposal.who.primary}</strong> (huvudansvarig)
          </p>
          {proposal.who.supporting.length > 0 && (
            <div>
              <p class="text-sm text-muted mb-2">Stod av:</p>
              <ul class="list-disc list-inside text-charcoal/80 space-y-1">
                {proposal.who.supporting.map((actor) => (
                  <li>{actor}</li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Kostnad -->
        <div>
          <h2 class="text-2xl text-ocean mb-4">Kostnad</h2>
          <div class="flex items-center gap-3">
            <span class={`inline-block px-4 py-2 rounded-lg text-sm font-semibold ${costColor(proposal.cost)}`}>
              {proposal.cost}
            </span>
            <div class="flex gap-1">
              {[1, 2, 3].map((level) => (
                <div class={`w-8 h-3 rounded-full ${
                  (proposal.cost === 'Liten' && level <= 1) ||
                  (proposal.cost === 'Medel' && level <= 2) ||
                  (proposal.cost === 'Stor' && level <= 3)
                    ? proposal.cost === 'Liten' ? 'bg-green-400' : proposal.cost === 'Medel' ? 'bg-amber-400' : 'bg-red-400'
                    : 'bg-gray-200'
                }`} />
              ))}
            </div>
          </div>
        </div>

        <!-- Foreningskopplingar -->
        {proposal.associations.length > 0 && (
          <div>
            <h2 class="text-2xl text-ocean mb-4">Foreningskopplingar</h2>
            <ul class="space-y-2">
              {proposal.associations.map((assoc) => (
                <li class="flex items-center gap-2 text-charcoal/80">
                  <span class="w-2 h-2 rounded-full bg-forest shrink-0"></span>
                  {assoc}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- Right Column: Sidebar -->
      <div class="space-y-6">
        <!-- Snabbfakta -->
        <div class="bg-white rounded-xl shadow-sm border border-border p-6">
          <h3 class="text-lg font-semibold text-ocean mb-4 font-sans">Snabbfakta</h3>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between">
              <dt class="text-muted">Typ</dt>
              <dd class="text-charcoal font-medium">{proposal.type}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted">Kostnad</dt>
              <dd class="text-charcoal font-medium">{proposal.cost}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted">Tidshorisont</dt>
              <dd class="text-charcoal font-medium">{proposal.timeline}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted">Malgrupp</dt>
              <dd class="text-charcoal font-medium">{proposal.targetGroup}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted">Sasong</dt>
              <dd class="text-charcoal font-medium">{proposal.season}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted">Plats</dt>
              <dd class="text-charcoal font-medium text-right max-w-[180px]">{proposal.location}</dd>
            </div>
          </dl>
        </div>

        <!-- Hallbarhet -->
        <div class="bg-white rounded-xl shadow-sm border border-border p-6">
          <h3 class="text-lg font-semibold text-ocean mb-4 font-sans">Hallbarhet</h3>
          <div class="space-y-4">
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-muted">Social</span>
                <span class="text-charcoal font-medium">{proposal.sustainability.social}/5</span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2.5">
                <div
                  class={`h-2.5 rounded-full ${sustainabilityColor(proposal.sustainability.social)}`}
                  style={`width: ${sustainabilityWidth(proposal.sustainability.social)}`}
                />
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-muted">Ekologisk</span>
                <span class="text-charcoal font-medium">{proposal.sustainability.ecological}/5</span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2.5">
                <div
                  class={`h-2.5 rounded-full ${sustainabilityColor(proposal.sustainability.ecological)}`}
                  style={`width: ${sustainabilityWidth(proposal.sustainability.ecological)}`}
                />
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-muted">Ekonomisk</span>
                <span class="text-charcoal font-medium">{proposal.sustainability.economic}/5</span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2.5">
                <div
                  class={`h-2.5 rounded-full ${sustainabilityColor(proposal.sustainability.economic)}`}
                  style={`width: ${sustainabilityWidth(proposal.sustainability.economic)}`}
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Theme Link -->
        <a
          href={`/tema/${theme.id}`}
          class="block bg-ocean/5 rounded-xl border border-ocean/20 p-6 hover:bg-ocean/10 transition-colors"
        >
          <p class="text-sm text-muted mb-1">Tillhor tema</p>
          <p class="text-ocean font-semibold flex items-center gap-2">
            <span class="text-xl">{theme.emoji}</span>
            {theme.name}
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-t border-border pt-8">
      {prevProposal ? (
        <a href={`/forslag/${prevProposal.id}`} class="inline-flex items-center text-ocean hover:text-ocean/80 transition-colors text-sm font-medium max-w-full truncate">
          &larr; #{prevProposal.id} {prevProposal.title}
        </a>
      ) : (
        <a href={`/tema/${theme.id}`} class="inline-flex items-center text-ocean hover:text-ocean/80 transition-colors text-sm font-medium">
          &larr; Tillbaka till tema
        </a>
      )}
      {nextProposal ? (
        <a href={`/forslag/${nextProposal.id}`} class="inline-flex items-center text-ocean hover:text-ocean/80 transition-colors text-sm font-medium max-w-full truncate sm:text-right">
          #{nextProposal.id} {nextProposal.title} &rarr;
        </a>
      ) : (
        <a href={`/tema/${theme.id}`} class="inline-flex items-center text-ocean hover:text-ocean/80 transition-colors text-sm font-medium">
          Tillbaka till tema &rarr;
        </a>
      )}
    </div>
  </section>
</BaseLayout>

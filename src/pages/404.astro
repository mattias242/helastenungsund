---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sidan hittades inte — Hela Stenungsund">
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">
      <div class="text-6xl md:text-8xl font-bold text-ocean/20 mb-6">404</div>
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">
        Sidan hittades inte
      </h1>
      <p class="text-muted text-lg leading-relaxed max-w-xl mx-auto mb-10">
        Vi kunde inte hitta sidan du letade efter. Kanske hittar du det du soker bland vara 100 forslag?
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center bg-sunset hover:bg-[#d4662f] text-white font-semibold px-8 py-3.5 rounded-xl transition-colors text-lg shadow-lg shadow-sunset/25"
        >
          Tillbaka till startsidan
        </a>
        <a
          href="/utforska"
          class="inline-flex items-center justify-center border-2 border-ocean text-ocean hover:bg-ocean hover:text-white font-semibold px-8 py-3.5 rounded-xl transition-colors text-lg"
        >
          Utforska forslag
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

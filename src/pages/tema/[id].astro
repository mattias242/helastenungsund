---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { themes } from '../../data/themes';
import { proposals } from '../../data/proposals';

export function getStaticPaths() {
  return themes.map((t) => ({
    params: { id: String(t.id) },
    props: { theme: t },
  }));
}

const { theme } = Astro.props;
const themeProposals = proposals.filter((p) => p.themeId === theme.id);
const prevTheme = themes.find((t) => t.id === theme.id - 1);
const nextTheme = themes.find((t) => t.id === theme.id + 1);
const themeImage = theme.image;

function truncate(text: string, max: number) {
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '...';
}

function costColor(cost: string) {
  switch (cost) {
    case 'Liten': return 'bg-green-100 text-green-800';
    case 'Medel': return 'bg-amber-100 text-amber-800';
    case 'Stor': return 'bg-red-100 text-red-800';
    default: return 'bg-gray-100 text-gray-800';
  }
}

function timelineColor(timeline: string) {
  switch (timeline) {
    case 'Quick win': return 'bg-green-100 text-green-800';
    case 'Medel': return 'bg-blue-100 text-blue-800';
    case 'Långsiktig': return 'bg-purple-100 text-purple-800';
    default: return 'bg-gray-100 text-gray-800';
  }
}
---

<BaseLayout title={`${theme.emoji} ${theme.name} - Hela Stenungsund`} description={theme.description}>
  <!-- Theme Banner Image -->
  <section class="relative h-64 md:h-80 lg:h-96 overflow-hidden">
    <img src={themeImage} alt={theme.name} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-ocean/80 via-ocean/40 to-ocean/20"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex flex-col justify-end pb-8 md:pb-12">
      <a href="/" class="inline-flex items-center text-white/80 hover:text-white transition-colors text-sm font-medium mb-4">
        &larr; Tillbaka
      </a>
      <div class="flex items-center gap-4 mb-2">
        <span class="text-4xl md:text-5xl">{theme.emoji}</span>
        <span class="text-sm font-semibold text-white/70 uppercase tracking-wider">Tema {theme.id}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl text-white mb-1">{theme.name}</h1>
      <p class="text-lg text-white/80">{theme.subtitle}</p>
    </div>
  </section>

  <!-- Theme Description -->
  <section class="bg-white border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">
      <p class="text-xl md:text-2xl italic text-charcoal/80 mb-4">
        &ldquo;{theme.question}&rdquo;
      </p>
      <p class="text-base text-muted leading-relaxed max-w-3xl">
        {theme.description}
      </p>
    </div>
  </section>

  <!-- Proposal Grid -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl text-ocean mb-8">10 forslag</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {themeProposals.map((p) => (
        <a
          href={`/forslag/${p.id}`}
          class="block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 border border-border group"
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-ocean/10 text-ocean text-xs font-bold">
              #{p.id}
            </span>
            <h3 class="text-lg font-semibold text-charcoal group-hover:text-ocean transition-colors font-sans">
              {p.title}
            </h3>
          </div>

          <p class="text-sm text-muted mb-2">{p.subtitle}</p>

          <p class="text-sm text-charcoal/70 leading-relaxed mb-4">
            {truncate(p.what, 100)}
          </p>

          <div class="flex flex-wrap gap-2">
            <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${costColor(p.cost)}`}>
              {p.cost}
            </span>
            <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${timelineColor(p.timeline)}`}>
              {p.timeline}
            </span>
            <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-sand text-muted">
              {p.season}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Navigation -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex justify-between items-center border-t border-border pt-8">
      {prevTheme ? (
        <a href={`/tema/${prevTheme.id}`} class="inline-flex items-center text-ocean hover:text-ocean/80 transition-colors text-sm font-medium">
          &larr; {prevTheme.emoji} {prevTheme.name}
        </a>
      ) : (
        <span></span>
      )}
      {nextTheme ? (
        <a href={`/tema/${nextTheme.id}`} class="inline-flex items-center text-ocean hover:text-ocean/80 transition-colors text-sm font-medium">
          {nextTheme.emoji} {nextTheme.name} &rarr;
        </a>
      ) : (
        <span></span>
      )}
    </div>
  </section>
</BaseLayout>
